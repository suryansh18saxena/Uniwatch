# ──────────────────────────────────────────────
# Byte-compiled / optimized / DLL files
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ──────────────────────────────────────────────
# Virtual Environments
# ──────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/

# ──────────────────────────────────────────────
# Environment Variables & Secrets
# ──────────────────────────────────────────────
.env
.env.*
*.env
secrets.json

# ──────────────────────────────────────────────
# SSH Keys & Certificates (NEVER commit these)
# ──────────────────────────────────────────────
*.pem
*.key
*.pub
*.ppk
id_rsa
id_ed25519
id_ecdsa

# ──────────────────────────────────────────────
# Django
# ──────────────────────────────────────────────
*.sqlite3
db.sqlite3
*.log
local_settings.py
/staticfiles/
/mediafiles/
media/

# ──────────────────────────────────────────────
# Prometheus Data (large time-series storage)
# ──────────────────────────────────────────────
prometheus/prometheus_data/
prometheus/data/

# ──────────────────────────────────────────────
# macOS
# ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ──────────────────────────────────────────────
# IDEs & Editors
# ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.orig
*~

# ──────────────────────────────────────────────
# Node (if frontend assets are added later)
# ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
dist/
build/

# ──────────────────────────────────────────────
# Coverage & Testing
# ──────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
coverage.xml
*.cover

# ──────────────────────────────────────────────
# Packaging
# ──────────────────────────────────────────────
*.egg-info/
dist/
build/
*.egg
MANIFEST

# ──────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────
*.bak
*.tmp
*.pid
