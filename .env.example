# Django Secret Key — CHANGE THIS in production!
# Generate a new one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Debug mode — set to False in production
DEBUG=True

# Prometheus URL — where Prometheus is running
PROMETHEUS_URL=http://localhost:9090

# Database (leave blank to use default SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/univatch
